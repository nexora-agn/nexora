# Supabase — get these from Project Settings → API in your Supabase dashboard
# Copy this file to .env.local and fill in the values.

# Client-side (safe to expose, protected by Row Level Security)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Public site URL (https, no trailing slash). Injected at build time into index.html
# for og:image, Twitter card, canonical, and JSON-LD. Optional on Vercel: builds also use
# VERCEL_URL automatically. A small script in index.html overwrites to location.origin
# in the browser so the live site always matches. Use this for local production-like builds
# or a fixed canonical domain.
# VITE_PUBLIC_SITE_URL=https://yourdomain.com

# Server-side only (used by the ZIP export API — NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ZIP export API (local dev server)
SITE_API_PORT=8787
SITE_ALLOWED_ORIGIN=http://localhost:8080

# Production only — point the admin dashboard at an external ZIP export API when
# you are hosting on a platform that cannot run the co-located serverless
# function (e.g. Hostinger static hosting). Leave unset on Vercel/Netlify —
# `api/export-site.mjs` will be used automatically.
# VITE_EXPORT_API_URL=https://your-export-api.example.com/api/export-site

# Chatbot — the floating AI assistant rendered inside every template.
# Without any of these the chatbot still works via a rule-based local brain that
# answers from the template's own site-data. Set ONE of the following to upgrade
# the preview to real LLM answers.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Override the chatbot endpoint at build time (client-side). Leave unset to use
# the bundled /api/chat (works on Vercel + the local dev:api server).
# VITE_CHAT_API_URL=https://your-chat-api.example.com/api/chat

# Form emails (Resend) — server-only for API key; set these in Vercel Production too.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Nexora <info@yourdomain.com>
# RESEND_ADMIN_EMAIL=info@yourdomain.com
# Optional: contact form only (defaults to RESEND_ADMIN_EMAIL)
# RESEND_CONTACT_EMAIL=info@yourdomain.com
# Internal “From” for team notifications (avoid same mailbox as From + To = self-send issues)
# RESEND_FROM_INTERNAL=Nexora <notifications@yourdomain.com>
