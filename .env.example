# Supabase — get these from Project Settings → API in your Supabase dashboard
# Copy this file to .env.local and fill in the values.

# Client-side (safe to expose, protected by Row Level Security)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Public site URL (https, no trailing slash). Injected at build time into index.html
# for og:image, Twitter card, canonical, and JSON-LD. A small script in index.html
# overwrites to location.origin in the browser. Set in Vercel if your canonical domain
# is not the default in code.
# VITE_PUBLIC_SITE_URL=https://yourdomain.com
#
# Server-only: same URL for form emails (Resend). Vercel’s VERCEL_URL is *.vercel.app and
# is NOT used for email links — set this (or VITE_PUBLIC_SITE_URL available to the API) so
# confirmation mail points at production.
# NEXORA_PUBLIC_URL=https://yourdomain.com

# Server-side only (used by the ZIP export API — NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ZIP export API (local dev server)
SITE_API_PORT=8787
SITE_ALLOWED_ORIGIN=http://localhost:8080

# Production only — point the admin dashboard at an external ZIP export API when
# you are hosting on a platform that cannot run the co-located serverless
# function (e.g. Hostinger static hosting). Leave unset on Vercel/Netlify —
# `api/export-site.mjs` will be used automatically.
# VITE_EXPORT_API_URL=https://your-export-api.example.com/api/export-site

# ---------------------------------------------------------------------------
# OpenClaw WebChat (floating widget) — optional
# ---------------------------------------------------------------------------
# Install CLI + daemon (machine that runs the gateway): npm i -g openclaw@latest && openclaw onboard --install-daemon
# Install web widget in this repo: npm i openclaw-webchat-react (already in package.json if used).
# Set the gateway WebSocket URL from your OpenClaw config (often ends with /ws; production should use wss://).
# Token/password must be safe for the browser if you use VITE_* (prefer a scoped webchat token).
# VITE_OPENCLAW_GATEWAY=wss://your-gateway.example.com/ws
# VITE_OPENCLAW_TOKEN=
# VITE_OPENCLAW_TITLE=Nexora assistant

# Optional API on another origin when your main host serves SPA HTML for /api/* (LiteSpeed try_files).
# Example: deploy this same repo to Vercel, add RESEND_* env vars there, then point here (no trailing slash):
# VITE_FORM_API_URL=https://your-app.vercel.app

# Production — Hostinger Node.js (Business / Cloud):
# • Build: npm run build
# • Start: MUST be **npm start** (runs server.js). If hPanel auto-filled **vite preview**, forms will
#   break with HTML 404 — vite preview only serves static files and has no /api/send-form-emails.
# • Entry file: server.js (framework type **Other** if those fields are hidden for “Vite”).
# • Env vars in hPanel must include RESEND_API_KEY (and Supabase keys if you use export API).

# Form emails (Resend) — server-only for API key; set these in Vercel Production too.
# (Set NEXORA_PUBLIC_URL above so mail links match your canonical site.)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Nexora <info@yourdomain.com>
# RESEND_ADMIN_EMAIL=info@yourdomain.com
# Optional: contact form only (defaults to RESEND_ADMIN_EMAIL)
# RESEND_CONTACT_EMAIL=info@yourdomain.com
# Internal “From” for team notifications (must differ from RESEND_ADMIN_EMAIL / To — self-send is often filtered)
# Default in code is notifications@… on your domain; override if you prefer another role address.
# RESEND_FROM_INTERNAL=Nexora <notifications@yourdomain.com>

# ---------------------------------------------------------------------------
# Paysera — checkout payment link + payment methods (server-side only token)
# ---------------------------------------------------------------------------
# Create the token in your Paysera account (OAuth2 / API access per their docs).
# Set in .env.local for `npm run dev` and in Vercel → Environment Variables for production.
#
# Bearer access token ONLY (do not include the word "Bearer").
# PAYSERA_ACCESS_TOKEN=
#
# Default amount in minor currency units when the admin UI does not pass purchase.amount.
# Example: 2500 = €25.00 when currency is EUR on the Paysera side.
# PAYSERA_PAYMENT_AMOUNT_MINOR=
#
# Optional: non-default Paysera API base (almost always omit).
# PAYSERA_API_ORIGIN=https://api.paysera.com
#
# Optional: max link lifetime (seconds) the server will allow when the client sends lifetime.
# PAYSERA_LINK_LIFETIME_MAX_SECONDS=2592000
#
# Optional: browser calls this origin for /api/paysera-* when SPA and API differ (e.g. static host).
# VITE_PAYSERA_PAY_API_ORIGIN=https://your-deployment.vercel.app
#
# Optional: full POST URL for payment link only (advanced; normally use VITE_PAYSERA_PAY_API_ORIGIN).
# VITE_PAYSERA_PAYMENT_LINK_URL=https://your-deployment.vercel.app/api/paysera-payment-link
