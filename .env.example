# Supabase — get these from Project Settings → API in your Supabase dashboard
# Copy this file to .env.local and fill in the values.

# Client-side (safe to expose, protected by Row Level Security)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only (used by the ZIP export API — NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ZIP export API
SITE_API_PORT=8787
SITE_ALLOWED_ORIGIN=http://localhost:8080
