# --- Chatbot (the floating AI assistant) -----------------------------------
# The chatbot is ALWAYS on. Without an AI key it answers via a local rule-based
# brain that reads /public/chatbot/site-data.json. Set ONE of the following to
# upgrade to real LLM answers.

# OpenAI (recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Legacy Flowise passthrough (optional)
FLOWISE_API_URL=
FLOWISE_API_KEY=

# Override the chatbot endpoint (client-side). Leave unset to use /api/chat.
# Useful when hosting on static-only platforms (Hostinger etc.) and proxying
# the chat through an external URL.
# VITE_CHAT_API_URL=https://your-chat-api.example.com/api/chat

# --- Dev API server (run: npm run dev:api) ---------------------------------
SITE_API_PORT=8787
SITE_ALLOWED_ORIGIN=http://localhost:8080
SITE_EXPORT_MAX_BODY_BYTES=300000000
