{
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@template/*": [
        "./src/template/*"
      ],
      "@template-summit/*": [
        "./src/template-summit/*"
      ],
      "@template-nexora/*": [
        "./src/template-nexora/*"
      ],
      "@template-roofix/*": [
        "./src/template-roofix/*"
      ],
      "@template-electrical/*": [
        "./src/template-electrical/*"
      ],
      "@template-plumbing/*": [
        "./src/template-plumbing/*"
      ],
      "@template-painting/*": [
        "./src/template-painting/*"
      ],
      "@template-familyfirst/*": [
        "./src/template-familyfirst/*"
      ],
      "@template-landscaping/*": [
        "./src/template-landscaping/*"
      ],
      "@template-homebuilder/*": [
        "./src/template-homebuilder/*"
      ],
      "@template-remodeler/*": [
        "./src/template-remodeler/*"
      ],
      "@template-mrbuildernyc/*": [
        "./src/template-mrbuildernyc/*"
      ]
    },
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}