{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@template/*": [
        "./src/template/*"
      ],
      "@template-summit/*": [
        "./src/template-summit/*"
      ],
      "@template-nexora/*": [
        "./src/template-nexora/*"
      ],
      "@template-roofix/*": [
        "./src/template-roofix/*"
      ],
      "@template-electrical/*": [
        "./src/template-electrical/*"
      ],
      "@template-plumbing/*": [
        "./src/template-plumbing/*"
      ],
      "@template-painting/*": [
        "./src/template-painting/*"
      ],
      "@template-familyfirst/*": [
        "./src/template-familyfirst/*"
      ],
      "@template-landscaping/*": [
        "./src/template-landscaping/*"
      ],
      "@template-homebuilder/*": [
        "./src/template-homebuilder/*"
      ],
      "@template-remodeler/*": [
        "./src/template-remodeler/*"
      ],
      "@template-mrbuildernyc/*": [
        "./src/template-mrbuildernyc/*"
      ],
      "@template-barbershop/*": [
        "./src/template-barbershop/*"
      ]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "types": [
      "vitest/globals"
    ],
    "useDefineForClassFields": true
  },
  "include": [
    "src"
  ]
}